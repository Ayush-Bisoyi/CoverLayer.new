{
  "name": "InsurerPartner", "type": "object",
  "properties": {
    "name": { "type": "string" },
    "country": { "type": "string" },
    "license_number": { "type": "string" },
    "regulatory_body": { "type": "string" },
    "contact_email": { "type": "string" },
    "active_policies_count": { "type": "number", "default": 0 },
    "total_coverage_issued": { "type": "number", "default": 0 },
    "loss_ratio": { "type": "number", "default": 0 },
    "status": { "type": "string", "enum": ["active","inactive","pending"], "default": "pending" },
    "supported_currencies": { "type": "array", "items": { "type": "string" } },
    "supported_verticals": { "type": "array", "items": { "type": "string" } }
  },
  "required": ["name", "country"]
}
