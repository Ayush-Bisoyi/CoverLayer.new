{
  "name": "Partner", "type": "object",
  "properties": {
    "company_name": { "type": "string" },
    "email": { "type": "string" },
    "website": { "type": "string" },
    "integration_type": { "type": "string", "enum": ["api","sdk","widget","no_code"] },
    "target_markets": { "type": "array", "items": { "type": "string" } },
    "status": { "type": "string", "enum": ["pending","active","suspended"], "default": "pending" },
    "api_key": { "type": "string" },
    "revenue_share_pct": { "type": "number", "default": 15 },
    "total_premium_volume": { "type": "number", "default": 0 },
    "total_policies_issued": { "type": "number", "default": 0 },
    "industry_vertical": { "type": "string", "enum": ["gig_economy","ecommerce","fintech","travel","marketplace","healthtech","other"] },
    "contact_name": { "type": "string" },
    "country": { "type": "string" }
  },
  "required": ["company_name", "email"]
}
